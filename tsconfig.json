{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES6", "DOM"],
    "types": ["cypress", "node"],
    "moduleResolution": "bundler",
    "module": "ESNext",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": false,
      "paths": {
        "@task/*": ["./cypress/e2e/task/*"],
        "@ui/*": ["./cypress/e2e/UI/*"],
        "@questions/*": ["./cypress/e2e/question/*"],
        "@assertion/*": ["./cypress/e2e/assertion/*"],
        "@fixtures/*": ["./cypress/fixtures/*"],
        "@action/*": ["./cypress/e2e/action/*"]
      }
  },
  "include": [
    "cypress/**/*.ts",
    "cypress/**/*.js",
    "cypress/**/*.d.ts"
  ]
}